@startuml CustomerCheckout
title Customer Checkout

actor Customer
participant "API Gateway" as Gateway
participant "customer-service" as CustomerService
participant "cart-service" as CartService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "MySQL Customer DB" as CustomerDB
database "PostgreSQL Cart DB" as CartDB
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Customer -> Gateway: POST /api/customers/checkout/\nnote
Gateway -> CustomerService: POST /customers/checkout/
CustomerService -> CustomerService: Validate JWT + role=CUSTOMER
CustomerService -> CartService: GET /carts/customer/{customer_id}/summary/
CartService -> CartDB: Load active cart + items
CartDB --> CartService: Cart summary
CartService --> CustomerService: Cart summary payload

alt Cart empty
    CustomerService --> Gateway: 400 cart is empty
    Gateway --> Customer: Show checkout error
else Cart has items
    loop For each cart item
        alt product_type = LAPTOP
            CustomerService -> LaptopService: GET /laptops/{id}/
            LaptopService -> LaptopDB: Load current stock
            LaptopDB --> LaptopService: Product row
            LaptopService --> CustomerService: Product detail
        else product_type = CLOTHES
            CustomerService -> ClothesService: GET /clothes/{id}/
            ClothesService -> ClothesDB: Load current stock
            ClothesDB --> ClothesService: Product row
            ClothesService --> CustomerService: Product detail
        end
        CustomerService -> CustomerService: Validate stock >= quantity
    end

    CustomerService -> CustomerDB: BEGIN TRANSACTION
    CustomerService -> CustomerDB: Insert Invoice(status=PENDING)
    loop For each validated item
        CustomerService -> CustomerDB: Insert InvoiceItem
        alt item is laptop
            CustomerService -> LaptopService: POST /laptops/{id}/stock-adjust/\ndelta = -quantity
            LaptopService -> LaptopDB: Reduce stock
            LaptopDB --> LaptopService: Updated stock
            LaptopService --> CustomerService: Success
        else item is clothes
            CustomerService -> ClothesService: POST /clothes/{id}/stock-adjust/\ndelta = -quantity
            ClothesService -> ClothesDB: Reduce stock
            ClothesDB --> ClothesService: Updated stock
            ClothesService --> CustomerService: Success
        end
    end
    CustomerService -> CustomerDB: Update Invoice(total_amount, status=PAID)
    CustomerDB --> CustomerService: Commit success

    CustomerService -> CartService: DELETE /carts/customer/{customer_id}/clear/
    CartService -> CartDB: Delete all active cart items
    CartDB --> CartService: Cart cleared
    CartService --> CustomerService: Clear success

    CustomerService --> Gateway: 201 invoice created
    Gateway --> Customer: Redirect to invoice history

    alt Any stock-adjust call fails after partial success
        CustomerService -> CustomerService: Reverse completed stock adjustments
        CustomerService -> CustomerDB: Rollback transaction
        CustomerService --> Gateway: 502 checkout failed
        Gateway --> Customer: Show failure message
    end
end
@enduml

