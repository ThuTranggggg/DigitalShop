@startuml CustomerCancelPendingInvoice
title Customer Cancel Pending Invoice

actor Customer
participant "API Gateway" as Gateway
participant "customer-service" as CustomerService
database "MySQL Customer DB" as CustomerDB

Customer -> Gateway: POST /api/customers/invoices/{invoice_id}/cancel/
Gateway -> CustomerService: POST /customers/invoices/{invoice_id}/cancel/
CustomerService -> CustomerService: Validate JWT + role=CUSTOMER
CustomerService -> CustomerDB: Load invoice by id + customer
CustomerDB --> CustomerService: Invoice row

alt status = PENDING
    CustomerService -> CustomerDB: Update status = CANCELLED
    CustomerDB --> CustomerService: Updated invoice
    CustomerService --> Gateway: Cancel success
    Gateway --> Customer: Refresh invoice detail
else status != PENDING
    CustomerService --> Gateway: 400 only pending invoices can be cancelled
    Gateway --> Customer: Show business-rule error
end
@enduml
