@startuml CustomerEnsureCart
title Customer Create Or Get Active Cart

actor Customer
participant "API Gateway" as Gateway
participant "customer-service" as CustomerService
participant "cart-service" as CartService
database "PostgreSQL Cart DB" as CartDB

Customer -> Gateway: POST /api/customers/cart/
Gateway -> CustomerService: POST /customers/cart/
CustomerService -> CustomerService: Validate JWT + role=CUSTOMER
CustomerService -> CartService: POST /carts/\ncustomer_id
CartService -> CartDB: Find active cart by customer_id

alt Active cart exists
    CartDB --> CartService: Existing cart row
    CartService --> CustomerService: Cart is ready
else No active cart
    CartService -> CartDB: Insert new Cart(status=ACTIVE)
    CartDB --> CartService: New cart row
    CartService --> CustomerService: Cart created
end

CustomerService --> Gateway: Cart payload
Gateway --> Customer: Cart ready
@enduml

@startuml CustomerAddItemToCart
title Customer Add Product To Cart

actor Customer
participant "API Gateway" as Gateway
participant "customer-service" as CustomerService
participant "cart-service" as CartService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "PostgreSQL Cart DB" as CartDB
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Customer -> Gateway: POST /api/customers/cart/items/\nproduct_type, product_id, quantity
Gateway -> CustomerService: POST /customers/cart/items/
CustomerService -> CustomerService: Validate JWT + role=CUSTOMER
CustomerService -> CartService: POST /carts/customer/{customer_id}/items/
CartService -> CartService: Validate payload\nquantity > 0
CartService -> CartDB: Find or create active cart
CartDB --> CartService: Active cart row

alt product_type = LAPTOP
    CartService -> LaptopService: GET /laptops/{id}/
    LaptopService -> LaptopDB: Load product detail
    LaptopDB --> LaptopService: Product row
    LaptopService --> CartService: name, price, stock
else product_type = CLOTHES
    CartService -> ClothesService: GET /clothes/{id}/
    ClothesService -> ClothesDB: Load product detail
    ClothesDB --> ClothesService: Product row
    ClothesService --> CartService: name, price, stock
end

alt Item already exists in cart
    CartService -> CartDB: Load existing CartItem
    CartDB --> CartService: Existing item
    CartService -> CartService: Increase quantity\nRe-check stock
    CartService -> CartDB: Update CartItem
else Item not in cart
    CartService -> CartDB: Insert CartItem
end

CartDB --> CartService: Saved cart item
CartService --> CustomerService: 201 item created
CustomerService --> Gateway: Add-to-cart success
Gateway --> Customer: Refresh mini cart / cart summary

alt Requested quantity exceeds stock
    CartService --> CustomerService: 400 stock error
    CustomerService --> Gateway: Validation error
    Gateway --> Customer: Show out-of-stock message
end
@enduml

@startuml CustomerUpdateCartItem
title Customer Update Cart Item Quantity

actor Customer
participant "API Gateway" as Gateway
participant "customer-service" as CustomerService
participant "cart-service" as CartService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "PostgreSQL Cart DB" as CartDB

Customer -> Gateway: PATCH /api/customers/cart/items/{item_id}/\nquantity
Gateway -> CustomerService: PATCH /customers/cart/items/{item_id}/
CustomerService -> CustomerService: Validate JWT + role=CUSTOMER
CustomerService -> CartService: PATCH /carts/customer/{customer_id}/items/{item_id}/
CartService -> CartDB: Find active cart + target CartItem
CartDB --> CartService: CartItem row

alt quantity = 0
    CartService -> CartDB: Delete CartItem
    CartDB --> CartService: Item removed
    CartService --> CustomerService: Item removed
else quantity > 0
    alt CartItem.product_type = LAPTOP
        CartService -> LaptopService: GET /laptops/{product_id}/
        LaptopService --> CartService: Current stock + price
    else CartItem.product_type = CLOTHES
        CartService -> ClothesService: GET /clothes/{product_id}/
        ClothesService --> CartService: Current stock + price
    end
    CartService -> CartService: Validate requested quantity <= stock
    CartService -> CartDB: Update CartItem quantity + price snapshot
    CartDB --> CartService: Updated item
    CartService --> CustomerService: Item updated
end

CustomerService --> Gateway: Updated cart result
Gateway --> Customer: Refresh cart summary
@enduml

