@startuml StaffLogin
title Staff Login

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
database "MySQL Staff DB" as StaffDB

Staff -> Gateway: POST /api/staff/login/\nusername, password
Gateway -> StaffService: POST /staff/login/
StaffService -> StaffService: Validate request payload
StaffService -> StaffDB: Find staff by username
StaffDB --> StaffService: Staff row + password hash
StaffService -> StaffService: Verify password\nGenerate JWT refresh/access
StaffService --> Gateway: success + access + refresh + staff profile
Gateway --> Staff: Login response

alt Invalid username or password
    StaffService --> Gateway: 400 login failed
    Gateway --> Staff: Show authentication error
end
@enduml

@startuml StaffDashboard
title Staff Dashboard Load

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "MySQL Staff DB" as StaffDB
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Staff -> Gateway: GET /api/staff/dashboard/\nAuthorization: Bearer JWT
Gateway -> StaffService: GET /staff/dashboard/
StaffService -> StaffService: Validate JWT + role=STAFF
par Load laptops
    StaffService -> LaptopService: GET /laptops/
    LaptopService -> LaptopDB: Query active/all laptop products
    LaptopDB --> LaptopService: Laptop rows
    LaptopService --> StaffService: Laptop list
and Load clothes
    StaffService -> ClothesService: GET /clothes/
    ClothesService -> ClothesDB: Query active/all clothes products
    ClothesDB --> ClothesService: Clothes rows
    ClothesService --> StaffService: Clothes list
and Load recent imports
    StaffService -> StaffDB: Query InventoryImportHistory
    StaffDB --> StaffService: Recent import rows
end
StaffService -> StaffService: Calculate totals\nBuild dashboard payload
StaffService --> Gateway: Dashboard data
Gateway --> Staff: Render staff dashboard

alt A product service is unavailable
    LaptopService --> StaffService: 5xx / timeout
    StaffService --> Gateway: 502 upstream service error
    Gateway --> Staff: Show dashboard error state
end
@enduml

@startuml StaffCreateProduct
title Staff Create Product

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Staff -> Gateway: POST /api/staff/{type}s/\nAuthorization + product payload
Gateway -> StaffService: POST /staff/{type}s/
StaffService -> StaffService: Validate JWT + role=STAFF
StaffService -> StaffService: Validate payload\nprice >= 0, stock >= 0

alt type = laptop
    StaffService -> LaptopService: POST /laptops/
    LaptopService -> LaptopService: Validate serializer
    LaptopService -> LaptopDB: Insert LaptopProduct
    LaptopDB --> LaptopService: New laptop row
    LaptopService --> StaffService: Created laptop payload
else type = clothes
    StaffService -> ClothesService: POST /clothes/
    ClothesService -> ClothesService: Validate serializer
    ClothesService -> ClothesDB: Insert ClothesProduct
    ClothesDB --> ClothesService: New clothes row
    ClothesService --> StaffService: Created clothes payload
end

StaffService --> Gateway: 201 product created
Gateway --> Staff: Refresh product table

alt Invalid data
    StaffService --> Gateway: 400 validation error
    Gateway --> Staff: Show field errors
end
@enduml

@startuml StaffUpdateProduct
title Staff Update Product

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Staff -> Gateway: PUT /api/staff/{type}s/{product_id}/
Gateway -> StaffService: PUT /staff/{type}s/{product_id}/
StaffService -> StaffService: Validate JWT + role=STAFF
StaffService -> StaffService: Validate payload

alt type = laptop
    StaffService -> LaptopService: PUT /laptops/{id}/
    LaptopService -> LaptopDB: Find + update LaptopProduct
    LaptopDB --> LaptopService: Updated laptop row
    LaptopService --> StaffService: Updated payload
else type = clothes
    StaffService -> ClothesService: PUT /clothes/{id}/
    ClothesService -> ClothesDB: Find + update ClothesProduct
    ClothesDB --> ClothesService: Updated clothes row
    ClothesService --> StaffService: Updated payload
end

StaffService --> Gateway: Product updated
Gateway --> Staff: Show success message

alt Product not found
    LaptopService --> StaffService: 404 not found
    StaffService --> Gateway: 502/404 mapped error
    Gateway --> Staff: Show missing product error
end
@enduml

@startuml StaffDeleteProduct
title Staff Delete Product

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Staff -> Gateway: DELETE /api/staff/{type}s/{product_id}/
Gateway -> StaffService: DELETE /staff/{type}s/{product_id}/
StaffService -> StaffService: Validate JWT + role=STAFF

alt type = laptop
    StaffService -> LaptopService: DELETE /laptops/{id}/
    LaptopService -> LaptopDB: Delete LaptopProduct
    LaptopDB --> LaptopService: Delete result
    LaptopService --> StaffService: 204 deleted
else type = clothes
    StaffService -> ClothesService: DELETE /clothes/{id}/
    ClothesService -> ClothesDB: Delete ClothesProduct
    ClothesDB --> ClothesService: Delete result
    ClothesService --> StaffService: 204 deleted
end

StaffService --> Gateway: Delete success
Gateway --> Staff: Remove row from table
@enduml

@startuml StaffImportStock
title Staff Import Stock

actor Staff
participant "API Gateway" as Gateway
participant "staff-service" as StaffService
participant "laptop-service" as LaptopService
participant "clothes-service" as ClothesService
database "MySQL Staff DB" as StaffDB
database "PostgreSQL Laptop DB" as LaptopDB
database "PostgreSQL Clothes DB" as ClothesDB

Staff -> Gateway: POST /api/staff/imports/\nproduct_type, product_id, quantity, note
Gateway -> StaffService: POST /staff/imports/
StaffService -> StaffService: Validate JWT + role=STAFF
StaffService -> StaffService: Validate quantity > 0

alt product_type = LAPTOP
    StaffService -> LaptopService: GET /laptops/{id}/
    LaptopService -> LaptopDB: Load product
    LaptopDB --> LaptopService: Current stock
    LaptopService --> StaffService: Product detail
    StaffService -> LaptopService: POST /laptops/{id}/stock-adjust/\ndelta = +quantity
    LaptopService -> LaptopDB: Update stock
    LaptopDB --> LaptopService: New stock
    LaptopService --> StaffService: Updated product
else product_type = CLOTHES
    StaffService -> ClothesService: GET /clothes/{id}/
    ClothesService -> ClothesDB: Load product
    ClothesDB --> ClothesService: Current stock
    ClothesService --> StaffService: Product detail
    StaffService -> ClothesService: POST /clothes/{id}/stock-adjust/\ndelta = +quantity
    ClothesService -> ClothesDB: Update stock
    ClothesDB --> ClothesService: New stock
    ClothesService --> StaffService: Updated product
end

StaffService -> StaffDB: Insert InventoryImportHistory
StaffDB --> StaffService: Import history row
StaffService --> Gateway: Import success + updated product + history
Gateway --> Staff: Show success and refresh dashboard
@enduml

